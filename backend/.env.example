# Backend environment variables
# Copy this file to .env and fill values

NODE_ENV=development

# Optional explicit URI (overrides local/live selection when set)
MONGODB_URI=

# Used in development/local mode
MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/sampledb

# Used when NODE_ENV=production
MONGODB_URI_LIVE=

# Required for JWT token generation/verification
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Required for interview chat and evaluation endpoints
GROQ_API_KEY=replace_with_real_groq_api_key
